{
    "version": "0.2.0",
    "configurations": [                
        {
            "name": "(gdb) Remote Debug", // 配置名称，可自定义            
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/aarch64/Debug/MB_DDF_Demo", // **本地**可执行文件的路径，须与ARM板上的程序一致
            "args": [], // 程序运行参数，如有需要在此添加
            "stopAtEntry": true, // 设为true可在main函数入口处自动暂停
            "cwd": "${workspaceFolder}", // 工作目录
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "D:\\\\Program Files (x86)\\\\Arm GNU Toolchain aarch64-none-linux-gnu\\\\11.3 rel1\\\\bin\\\\aarch64-none-linux-gnu-gdb.exe", // **重要**：指向你Windows上交叉编译工具链内的GDB
            "miDebuggerServerAddress": "192.168.1.29:1234", // **重要**：你的开发板IP和gdbserver监听端口
            "setupCommands": [
                { "description": "Enable pretty-printing", "text": "-enable-pretty-printing", "ignoreFailures": true },
                { "description": "GDB: turn off thread event printing", "text": "set print thread-events off", "ignoreFailures": true },
                { "description": "GDB: turn off pagination", "text": "set pagination off", "ignoreFailures": true },
                { "description": "Handle SIGUSR1 without stopping", "text": "handle SIGUSR1 nostop noprint pass", "ignoreFailures": true },
                { "description": "Handle SIGUSR2 without stopping", "text": "handle SIGUSR2 nostop noprint pass", "ignoreFailures": true },
                { "description": "Handle realtime signals without stopping", "text": "handle SIGRTMIN nostop noprint pass", "ignoreFailures": true },
                { "description": "Handle SIG34 explicitly", "text": "handle SIG34 nostop noprint pass", "ignoreFailures": true },
                // 设置sysroot
                {
                    "description": "Set sysroot for cross-compilation",
                    "text": "set sysroot \\\\",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}
